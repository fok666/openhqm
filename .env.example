# OpenHQM configuration. Copy to .env and adjust. All vars are optional (defaults shown).

# --- http-to-queue mode (HTTP server) ---
OPENHQM_SERVER__HOST=0.0.0.0
OPENHQM_SERVER__PORT=8000
OPENHQM_SERVER__WORKERS=4

# --- Queue (shared by both modes) ---
OPENHQM_QUEUE__TYPE=redis
OPENHQM_QUEUE__REDIS_URL=redis://localhost:6379
OPENHQM_QUEUE__REQUEST_QUEUE_NAME=openhqm-requests
OPENHQM_QUEUE__DLQ_NAME=openhqm-dlq

# --- Cache (stores results for polling) ---
OPENHQM_CACHE__TYPE=redis
OPENHQM_CACHE__REDIS_URL=redis://localhost:6379
OPENHQM_CACHE__TTL_SECONDS=3600

# --- queue-to-http mode (worker + backend) ---
OPENHQM_WORKER__BATCH_SIZE=10
OPENHQM_WORKER__MAX_RETRIES=3
# The backend the worker forwards to — usually the local app in a sidecar:
OPENHQM_PROXY__BACKEND_URL=http://localhost:8080
OPENHQM_PROXY__TIMEOUT=300
# Optional method override ("" = use the request's method), auth, and header rules:
# OPENHQM_PROXY__METHOD=POST
# OPENHQM_PROXY__AUTH_TYPE=bearer        # bearer | basic | api_key | custom
# OPENHQM_PROXY__AUTH_TOKEN=your-token
# OPENHQM_PROXY__FORWARD_HEADERS=["Content-Type","Accept","User-Agent"]   # ["*"] forwards all
# OPENHQM_PROXY__STRIP_HEADERS=["Host","Connection"]

# --- Observability ---
OPENHQM_MONITORING__LOG_LEVEL=INFO
OPENHQM_MONITORING__LOG_FORMAT=json
